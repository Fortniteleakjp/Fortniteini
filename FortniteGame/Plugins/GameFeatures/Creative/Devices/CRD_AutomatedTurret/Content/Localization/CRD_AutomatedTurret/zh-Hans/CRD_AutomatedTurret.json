  "UserOptionDefinition": {
    "Device_AutomatedTurret_C.ActivationRadius.DisplayName": "激活半径",
    "Device_AutomatedTurret_C.AllowIdleRotation.DisplayName": "允许空闲旋转",
    "TurretOption_RotateType.Back and Forth.DisplayName": "往返",
    "Device_AutomatedTurret_C.bCanTargetAI.DisplayName": "可以 AI 为目标",
    "Device_AutomatedTurret_C.bCanTargetCreatures.DisplayName": "能够以生物为目标",
    "Device_AutomatedTurret_C.bCanTargetGuards.DisplayName": "可以守卫为目标",
    "Device_AutomatedTurret_C.bCanTargetPlayers.DisplayName": "可以玩家为目标",
    "Device_AutomatedTurret_C.bCanTargetWildlife.DisplayName": "可以野生动物为目标",
    "Device_AutomatedTurret_C.ClearTarget.DisplayName": "清除目标",
    "Device_AutomatedTurret_C.ClearTarget.Description": "清除当前目标，令自动炮塔返回到普通瞄准。如瞄准已启用，设备可能重新获取当前目标。",
    "Device_AutomatedTurret_C.DefaultTeam.DisplayName": "默认队伍",
    "Device_AutomatedTurret_C.DelayBeforeFiring.DisplayName": "射击前延迟",
    "Device_AutomatedTurret_C.DestructionBehavior.DisplayName": "摧毁行为",
    "Device_AutomatedTurret_C.ActivationRadius.Description": "确定设备在多少米以外不会激活。",
    "Device_AutomatedTurret_C.IdleRotationAngle.Description": "确定炮塔在搜索潜在目标时可旋转的距离。",
    "Device_AutomatedTurret_C.DelayBeforeFiring.Description": "确定炮塔锁定目标后开始射击前的等待时间（以秒为单位）。",
    "Device_AutomatedTurret_C.DisabledDuration.Description": "确定炮塔被摧毁后禁用时长。无限——须手动操作才可重新启用炮塔。",
    "Device_AutomatedTurret_C.TurretDamage.Description": "决定炮塔每次射击造成的伤害。淘汰——炮塔的射击会立即淘汰目标。",
    "Device_AutomatedTurret_C.DeviceHealth.Description": "确定此设备的生命值多少，或是否坚不可摧。",
    "Device_AutomatedTurret_C.IdleRotationMultiplier.Description": "确定炮塔在搜索潜在目标时旋转的速度。",
    "Device_AutomatedTurret_C.TrackingRotationMultiplier.Description": "确定炮塔在追踪发现目标或寻找对其造成伤害的人时的旋转速度。",
    "Device_AutomatedTurret_C.RotationStyle.Description": "确定炮塔如何在旋转的同时搜索潜在目标。",
    "Device_AutomatedTurret_C.MaxTargetDistance.Description": "确定当有人在激活半径内时炮塔可检测到目标的距离。默认数据小于激活半径。禁用后，哨兵将不会自动瞄准，需要通过设置目标功能手动瞄准。",
    "Device_AutomatedTurret_C.RateOfFire.Description": "确定每次射击间隔时间（以秒为单位）。",
    "Device_AutomatedTurret_C.WireDamageMultiplier.Description": "确定对炮塔引线造成伤害的加成。",
    "Device_AutomatedTurret_C.PercentHealthRestored.Description": "确定此设备被摧毁后重新启用时恢复的最大生命值比例。",
    "Device_AutomatedTurret_C.DestructionBehavior.Description": "确定炮塔被摧毁后的事件。如设置为爆炸，爆炸不造成伤害。",
    "Device_AutomatedTurret_C.WireAngle.Description": "确定引线与炮塔基座连接的位置。",
    "Device_AutomatedTurret_C.bCanTargetAI.Description": "确定炮塔是否能以 AI 守卫、野生动物及生物为目标。",
    "Device_AutomatedTurret_C.bCanTargetCreatures.Description": "确定炮塔是否能以生物为目标。",
    "Device_AutomatedTurret_C.bCanTargetGuards.Description": "确定炮塔是否能以守卫为目标。",
    "Device_AutomatedTurret_C.bCanTargetWildlife.Description": "确定炮塔是否能以野生动物为目标。",
    "Device_AutomatedTurret_C.bCanTargetPlayers.Description": "确定炮塔是否能以玩家为目标。",
    "Device_AutomatedTurret_C.AllowIdleRotation.Description": "确定炮塔是否旋转搜索潜在目标。",
    "Device_AutomatedTurret_C.bGoDormantIfAlone.Description": "确定激活半径内没有目标时，炮塔是否回到基座。",
    "Device_AutomatedTurret_C.bStartEnabled.Description": "确定游戏开始时此设备是否启动。",
    "Device_AutomatedTurret_C.bShowWire.Description": "确定是否显示与炮塔基座相连的引线。",
    "Device_AutomatedTurret_C.StartingTeamType.Description": "确定游戏开始时炮塔分配至的队伍，通过事件进行交换。队伍索引——使用默认队伍指定的队伍。",
