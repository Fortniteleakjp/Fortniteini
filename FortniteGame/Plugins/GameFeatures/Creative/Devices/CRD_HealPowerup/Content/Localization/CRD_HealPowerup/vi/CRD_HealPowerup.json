  "UserOptionDefinition": {
    "Enum_Device_Creative_Powerup_Heal_Effect_V2.% Decrease.DisplayName": "% Giảm",
    "Enum_Device_Creative_Powerup_Heal_Effect_V2.% Increase.DisplayName": "% Tăng",
    "Creative_Powerup_HealthPowerup_V2_C.Respawn.Description": "Sau khi nhặt, tái tạo lại vật phẩm này sau một khoảng thời gian tùy chỉnh được thiết lập trong một tùy chọn bổ sung, hoặc nếu đặt là Không thì sẽ không bao giờ được tái tạo.",
    "Enum_Creative_Powerup_Visibility.All.DisplayName": "Tất Cả",
    "Enum_Creative_Powerup_Applicability.All players.DisplayName": "Tất cả người chơi",
    "Creative_Powerup_HealthPowerup_V2_C.bAmbientAudio.DisplayName": "Âm Thanh Xung Quanh",
    "ECreativeClassType.Any.DisplayName": "Bất Kỳ",
    "ECreativeTeamType.Any.DisplayName": "Bất Kỳ",
    "Creative_Powerup_HealthPowerup_V2_C.ApplyTo.DisplayName": "Áp Dụng Cho",
    "Enum_Device_Creative_Powerup_Heal_StatToModify_V2.Both.DisplayName": "Cả hai",
    "ClassSlotMetaData.DisplayPattern": "Nghề {0}",
    "Creative_Powerup_HealthPowerup_V2_C.Clear.DisplayName": "Xóa",
    "Creative_Powerup_HealthPowerup_V2_C.Clear.Description": "Xóa hiệu ứng tăng cường này nếu đang được áp dụng.",
    "Creative_Powerup_HealthPowerup_V2_C.Despawn.DisplayName": "Thu Hồi",
    "Creative_Powerup_HealthPowerup_V2_C.InfiniteEffectDuration.Description": "Xác định xem thời gian duy trì hiệu lực của hiệu ứng được áp dụng có phải là vô hạn hay không. Nếu đặt là Không, một tùy chọn bổ sung để thiết lập thời gian tùy chỉnh sẽ xuất hiện.",
    "Creative_Powerup_HealthPowerup_V2_C.bAmbientAudio.Description": "Xác định xem vật thể có phát âm thanh xung quanh khi có người chơi ở gần hay không.",
    "Creative_Powerup_HealthPowerup_V2_C.StatToModify.Description": "Xác định chỉ số nào sẽ bị ảnh hưởng bởi sức mạnh tăng cường này.",
    "70F6CFC84A15691E3A955A874B12B962": "Tắt Hiệu Ứng Khi Nhặt",
    "Creative_Powerup_HealthPowerup_V2_C.Effect.DisplayName": "Hiệu Ứng",
