  "Juno_UpdateItemData": {
    "59D9FBC94B1DF82CC5233AA46BAD70C3": "可製作成精美戰利品的傳奇魚。",
    "775C11E1400318A2FFB00B8F65B12CCB": "可製作成精美戰利品的傳奇魚。",
    "DD83FDA2475386ECFD5E1580121BD63D": "可製作成精美戰利品的傳奇魚。",
    "1F5641484728D4C6F186408D3BA53800": "基本的彎刀，適合用來清理草叢和危險的植物。",
    "8B7F786049D66DF063CE9587B226DD87": "基本的彎刀，適合用來清理草叢和危險的植物。",
    "11EE0ED84E840372E893DEB51402290F": "附有炸藥的基本盾牌。受到傷害時會爆炸一次。",
    "3C3F26F940A7C70E9D8562B14C9EC91B": "基本的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "440FF53B44923330245009A00599C5CE": "基本的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "77F276E941F032E9DD3B5E98827657C1": "基本的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "AE0684EE4328A34CD472D7866AE2A2C3": "會發出恐怖惡臭的魚。可加工製成臭腺。",
    "BCCEA0BB463A73013EDAB99230C5973C": "能產生電力的魚。可加工製成電能池。",
    "0C3A02D748B8AA5FE69C978D8625461B": "充滿氣體的囊袋，從各種小動物身上掉落，散發著難聞的氣味。",
    "A6952D794EDE0B3673FCF8AF5AF9E327": "出現在岩洞的沉重寶石。",
    "00D321414DE5EFF8D70D008D1DC6B2C5": "出現在失落島嶼的沉重石頭。",
    "5D82F3EF415AE8B23FC963AF2A467453": "有點脆，有點毛，有點美味。",
    "45AF85894D437A4C49B68CB2D2149424": "強大的彎刀，適合用來清理草叢和危險的植物。",
    "852ED43A404399447A62AEB1A7F480EF": "強大的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "6E27CD4142ACEED6155D4387DAA2F61C": "出現在岩洞的珍貴金屬。",
    "4742C3BC4A862AB957F76B8AFC38AA1A": "出現在失落島嶼的珍貴木材。",
    "A622D1224DBBBBEEDA8026BDA610B645": "可以種出龍寶莓植物的種子。",
    "F2F14E594A4674541021218799A3EBB6": "可以種出番茄植物的種子。",
    "3EE7EB114A7F6F4D1F9E26AC973DDAED": "格擋傷害的盾牌。邊擋邊衝刺，衝向物體來將其撞飛。",
    "98B596B64A9A056E8ABDD4BDF6BF2E71": "堅固的匕首，適合近戰。從背後攻擊目標時可造成暴擊。",
    "F8460BED41BEDFD172999FA12F67D318": "堅固的匕首，適合近戰。從背後攻擊目標時可造成暴擊。",
    "B6885DEC4DDCCC3B2B67A782E17488FC": "有力的彎刀，適合用來清理草叢和危險的植物。",
    "63C1466A421A0828D289A4BC575A9E06": "有力的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "969C7EFF4E3CA058409606980A07766A": "牢固的彎刀，適合用來清理草叢和危險的植物。",
    "95C1716D4A51B020BABBE584F0D6C42C": "牢固的矛，適合近戰。輕觸可攻擊。長按可投出。",
    "4C0E9AB344BAAC46532095B5C284FEA0": "脆弱的盾牌，損壞時會爆裂",
    "74C657D34DF13DC57F0A88BF12DAB571": "脆弱的盾牌，損壞時會爆裂",
    "6A94E13F4CEB03BCB749909001E552B2": "幾乎無人能擋。",
    "2B9F059D4FD491E2FA8E769205669B38": "供爆裂盾牌使用的彈藥。",
    "43A69BD0445293CE716C3992F6EAFC11": "製作物品的關鍵材料。",
    "12FCAC7C44D4AEADC60DC59E5756FB71": "爆裂盾牌",
    "3F664664465A3141F5FAAA99D279CB27": "爆裂盾牌",
    "7082629947BF43219BACD6B0124C9946": "爆裂盾牌",
    "782547E1439C527D06852B9943AFE58C": "早餐是一日之計。",
    "6641231041D11E725FB0289A35165DFF": "光芒強烈，風味更強烈。",
    "930D81C348DA245DF3A55AB204BA5352": "有益健康？",
    "225398E04EC3A71E9BC2368C658C49C8": "冰涼、烤焦、努力。",
    "78AF136F43C32224FA5AFA99C9E7969C": "從熊身上收集的。",
    "50F8610A4360FF6376AE6DAEB3715CF2": "從霜熊身上收集的。",
