  "Juno_UpdateItemData": {
    "A5A5DDA345214DD154779A8A30F4AD23": "Ein gemütliches Heim für die tierischen Freunde, die in deinem Dorf leben.",
    "854FCBFD4B1FA3669BEC7DAF30198F1B": "Eine kleine Leckerei, die Tiere für begrenzte Zeit dazu bewegt, dir zu folgen. Nützlich, wenn du deine tierischen Freunde in eine Scheune deines Dorfes locken willst.",
    "335BA58A49ECF287FBA421882B38679E": "Ab ins Heu!",
    "4A3A2B9249462903EEE37F9A2AE50A96": "Nur für Tiere. Echt schade."
  }
