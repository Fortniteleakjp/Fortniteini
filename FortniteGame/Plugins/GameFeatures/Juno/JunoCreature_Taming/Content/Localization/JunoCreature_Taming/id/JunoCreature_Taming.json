  "Juno_UpdateItemData": {
    "A5A5DDA345214DD154779A8A30F4AD23": "Rumah nyaman untuk teman-teman hewan yang tinggal di desamu.",
    "854FCBFD4B1FA3669BEC7DAF30198F1B": "Camilan lezat yang meyakinkan hewan untuk mengikutimu dalam waktu terbatas. Berguna untuk memimpin teman hewan ke lumbung di Desamu.",
    "335BA58A49ECF287FBA421882B38679E": "Waktunya tidur!",
    "4A3A2B9249462903EEE37F9A2AE50A96": "Hanya untuk hewan. Maaf."
  }
