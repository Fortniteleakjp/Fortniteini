  "Juno_UpdateItemData": {
    "B2D2288E46DC8D78827B23A638B1B077": "Zwykła siekiera. Doskonale nadaje się do zbierania drewna – albo do obrony.",
    "7CB9F76A4597E83BCABB02B1BF4CB829": "Zwykła kusza. Idealna do atakowania wrogów z daleka.",
    "C80FB02946126C5E19F6D18DB840CFC1": "Zwykły sztylet. Doskonały do walki w zwarciu. Uderzenie celu od tyłu powoduje trafienie krytyczne.",
    "D3971327467EAE7F3E037C8B6E9A5544": "Zwykła maczeta. Bardzo ułatwia przebijanie się przez krzaki i niebezpieczne rośliny.",
    "1D70BE7242DD41810C1027B2A8523638": "Zwykły kilof. Umożliwia pozyskiwanie kamienia z obiektów i jest bardzo skuteczny przeciw budowlom.",
    "75B3C8CE4829637CDC94389D171D4009": "Zwykła włócznia, służąca do walki z bliska lub na dystans. Dotknij, by zaatakować. Przytrzymaj, by rzucić.",
    "AE0D8348498DCB8EA0014BB4420AA4F8": "Zwykły miecz. Idealny do walki wręcz.",
    "7CF409744D7B83E5180CBE80AFAF26F6": "Legendarny sztylet. Przeniesiony z innego wymiaru. Doskonały do walki w zwarciu. Uderzenie celu od tyłu powoduje trafienie krytyczne.",
    "EC33B7F74C1B2100DA4045A59D73EC88": "Legendarna maczeta. Przeniesiona z innego wymiaru. Bardzo ułatwia przebijanie się przez krzaki i niebezpieczne rośliny.",
    "C9B55874497611D1854DACA09C73D7A8": "Legendarna włócznia. Przeniesiona z innego wymiaru do walki z bliska lub na dystans. Dotknij, by zaatakować. Przytrzymaj, by rzucić.",
    "A60C95B3484DD3B81129C0B646569FBE": "Rzadka siekiera. Doskonale nadaje się do zbierania drewna – albo do obrony.",
    "534E2E624D3CD2D30F1D948053F04597": "Rzadka kusza. Idealna do atakowania wrogów z daleka.",
