    "DFBBD2C04C1C1F4DE55F33AB12BDD4C6": "Tombak",
    "F3BF3D29485D0071FFF3529C48DA3489": "Tombak",
    "907AD77945DFD8C8C4C38A948C859E52": "Pecahkan logam berat dengan Beliung berat ini.",
    "BD75370244C7062E54C0209895D54EFA": "Cukup kuat untuk menebang pohon ... atau musuhmu.",
    "37A9316446CA01F80CA0489FDD3F928B": "Pedang",
    "445DECA4404990A271E2469619B89721": "Pedang",
    "740F44584989B1296E4B90BD6EC266CE": "Pedang",
    "F927D39A4690B96889977987DC2D80F2": "Pedang",
    "3A6BE95246AE2DDA48C0EF9B206B29DD": "Kalahkan lawan terberatmu!",
    "DADA8B8344C5E0D46FA9199AB37C0446": "Hadapi musuh yang lebih kuat.",
    "5963BECB41E4E16BA39965BFFDF6B1B3": "Tebang pohon sedikit demi sedikit.",
    "32FA1E084CE463DB1A89509F8196A913": "Belati pamungkas.",
    "EC74A49744BF5644982B2792E16C9CC0": "Tombak pemungkas.",
    "5483161E4AA90C413B01CEBB2888422E": "Mereka harus berhati-hati.",
    "E2E57D294F910660ADFC5F98604CDACA": "Mereka tak akan menduganya.",
    "113D637040C3D4CE6FF462B5B114C376": "Batu-batuan ini tak akan mampu menahannya.",
