    "7335459E41D2C651194CB8B3B9CFD72E": "Beliung",
    "9B7BAD5743155A086483489FFCF2F762": "Beliung",
    "A5A6441C4624F4468A09EE8BF613891C": "Beliung",
    "F0B2B4CB483C76A9341CB7A1C49F75E4": "Tebas dan iris!",
