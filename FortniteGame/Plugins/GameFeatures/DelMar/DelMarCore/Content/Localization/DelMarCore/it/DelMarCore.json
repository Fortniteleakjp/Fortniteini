    "92F738D5459C3BE2ADF108955A72CDDE": "Del Mar: rotazione gara di velocità",
    "DE90B8ED4613FA3031C4A0AF84DE58B9": "Del Mar: rotazione Gara di velocità",
    "A45FBC554386D2CEF76E61BD1F9CAB78": "Del Mar: tutorial",
