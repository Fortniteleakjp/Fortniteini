    "173946F24B1E24229C3F7CB959E4C975": "ماسي II",
    "471246174E4A0B36C0039A8235B9C9AC": "ماسي III",
    "5E3B1D8F4C9948488A7F07AB7F65D0A9": "قُد في أفضل مسار ممكن!",
    "896ADBCC4F1D226C457B16A08ED2ECB0": "القيادة على المضمار أسرع من الطيران في الهواء، لكن أفضل الطرق المختصرة قد تتطلب التحليق في السماء.",
    "3BF328704B8D2E45F4AE6EAB72065BB4": "نخبوي",
    "BFB631A745C01BB892803B92219C97CA": "ستمنحك متابعة السيارات الأخرى عن كثب في سباق مصنف تعزيزًا لسرعة الانجراف!",
    "E77FC4D04EE0F95C7E08F5B80550D1E1": "ذهبي I",
    "13F7949E4194763AA29776816A96AE8C": "ذهبي II",
    "A9317DAC4DFAC2C334623CB4E4BAE3CB": "ذهبي III",
    "D96F899743EE8351771FC9AA329A743F": "إذا لم تكن سعيدًا بأدائك على مضمار في محاولات السرعة، فأعد تعيين السباق لإعادة المحاولة!",
    "497642EE43007F4247719B8F90BC9E62": "في السباق المصنف، قم بزيادة السرعة مع تحوّل الضوء الأخير إلى اللون الأخضر عند خط البداية للحصول على تعزيز للسرعة!",
    "044A745B46AB68DA29F2F99B0B276718": "حركات الانقلاب رائعة!",
    "B2F78F7749F571A8B884468AB688F546": "جارٍ التحميل",
    "1EDA63B94211955ADD9025AEFE88B554": "حاجز",
    "F77EEB2F4CFC9E2686161F908E0597E0": "يبدأ الوقت الإضافي في محاولات السرعة عندما ينتهي مؤقت المباراة ولا يزال اللاعبون يكملون المضمار. استخدم الوقت الإضافي بحكمة!",
    "1992292D4F2147853C3785946BCE4DE3": "بلاتيني I",
    "404083064234E991AC765E930E875C62": "بلاتيني II",
    "85A1C5064D1A04EAC051238F7882EDC4": "بلاتيني III",
    "F73DE19643FE0CE78891A3A64205AE8E": "تعرض الصور الرمزية للاعب الموجودة في أسفل الشاشة اللاعبين الموجودين خلفك مباشرةً في السباق المصنف.",
    "6372FFB247E5DE6F4E7569BED791F241": "اضغط على زر التربو مرة أخرى عندما ترى الرسالة الوامضة التي تطالب بتعزيز إضافي للسرعة!",
