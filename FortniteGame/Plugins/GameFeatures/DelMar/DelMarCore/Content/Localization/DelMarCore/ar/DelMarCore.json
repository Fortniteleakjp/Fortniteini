    "46F8465244FBF2850609C6A87F8FCC3C": "ارتقِ في التصنيف للعب على مضامير أكثر صعوبة في السباق المصنف!",
    "090299C1474FFEF4E66FE087D05C4299": "يضعك السباق المصنف في مواجهة لاعبين آخرين في تحدٍّ مثير للوصول إلى خط النهاية!",
    "FF6F270447C58117EC5CC59BF1ED2B34": "فضي I",
    "63B4564E47652FBC7198789FF748433E": "فضي II",
    "2E70094B4AD5D2E82267E7A4A3E00C1F": "فضي III",
    "F4EC3FBA41231F5577FF21930297A66C": "شاهد اللاعبين الآخرين في وضع محاولات السرعة لمعرفة كيف يتعاملون مع المضمار!",
    "8020E2B742675A7E13D0A5BDC3A8D652": "تُعاد تعيين سجلات محاولات السرعة في تحديث التصنيف التالي. ",
    "3E2F931F43FCFB5E744587A7277DCDCD": "اجعل سيارتك تسير باستقامة للخروج من الانزلاق!",
    "D4A86EEE478D3D2ED3718F905DACF963": "تمثل السيارة الذهبية التي تظهر في مضامير محاولات السرعة أفضل محاولاتك في المباراة. تحدّى نفسك وابلغ القمة!",
    "050CF3AE4B8C8A43A4B2539D6DABEE66": "يتم شحن عداد التربو ببطء من تلقاء نفسه. انزلق لشحنه بشكل أسرع!",
    "DBBFB88B49BDD363CC2D8089610E8B50": "كلما أحرزت مركزًا أعلى، زادت سرعة صعودك في الرتب في السباق المصنف!",
    "1A31A06F46CC76E57F3AD8A65473ECD6": "كلما زاد طول الانزلاق، زاد تعزيز السرعة. ",
    "D49588164695933A5241A28747B23EA0": "يستمر مؤقت المباراة في محاولات السرعة في العمل أثناء مشاهدة سجلات المباراة أو عرضها -- استغل وقتك بحكمة!",
    "D35FE5CE4B7E075ECF2EB2BD1DBB041A": "لا تتصادم المركبات ببعضها البعض في مضامير محاولات السرعة.",
    "6DF8A2D74CAAC62C60EE55913829170D": "غير مصنّف",
    "A14F3D5D46A401A217DDE9A26DE557D9": "Unreal",
    "3119F2BA40E4EBC9DE06359B1179C327": "استخدم مراوغة هوائية للالتصاق بسرعة على أي سطح في أثناء وجودك في الهواء!",
    "05F48B9E4244FFE340ADEDB06B68E072": "استخدم الانزلاق الصاروخي لأخذ المنعطفات بزاوية أكثر حدة!",
    "4980DED74337F9845952999C883A45E2": "يمكن أن تساعدك إعادة تعيين المركبة على العودة بسرعة إلى المضمار. تحقَّق من إعدادات وحدة التحكُّم لمعرفة المدخلات!",
    "CB28F1D54D71A0BFF7C7979EC097DE1B": "يمكنك الارتقاء في الرتب في السباق المصنف مع ما يصل إلى ثلاثة أصدقاء آخرين! كوّن فريقًا واكتسح المنافسة!",
    "6D769DB64CDF53F9CB537C88DAE2D26D": "يمكنك تخصيص سيارتك في الخزانة.",
    "FD21D46E41B8467ECE2E5CA2BC020448": "يمكنك تخصيص عناصر التحكم في قائمة الإعدادات.",
    "ED6A28FF4001E405CCF9CA9286147E1D": "يمكنك السباق بشكل عرضي على أي مضمار في فِرَق تصل إلى 12 لاعبًا! ",
    "312D61D140EBADF195FBD2A775705462": "يمكنك تخزين ما يصل إلى ثلاثة شواحن تربو في وقت واحد! استخدمها وإلا ستفقدها!",
    "1D8FAEF8409F59AED06DF4BED529D89D": "توفر دافعات سيارتك وقتًا محدودًا للطيران. تتم إعادة شحن الدافعات على الفور عند الهبوط على سطح ما."
  },
